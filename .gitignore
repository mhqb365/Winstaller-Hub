# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Aa]rtifacts/
[Pp]ublish/
out/
logs/
*.log

# .NET generated files
*.cache
*.pidb
*.svclog
*.scc
*.pdb
*.mdb
*.opendb
*.VC.db
*.dbmdl
*.jfm
*.psess
*.vsp
*.vspx

# User-specific files
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.DotSettings.user

# Visual Studio / IDE folders
.vs/
.vscode/
.idea/
*.code-workspace

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
!**/[Pp]ackages/repositories.config
.nuget/packages/

# Test output
[Tt]est[Rr]esult*/
[Tt]est[Rr]esults/
*.trx
*.coverage
*.coveragexml

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# OS generated files
Thumbs.db
Desktop.ini
.DS_Store

# Misc temporary files
*.tmp
*.temp
*.bak
*.orig
*.swp
*.swo

.agent