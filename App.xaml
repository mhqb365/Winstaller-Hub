<Application x:Class="WinstallerHubApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AccentBrush" Color="#00AADE" />

            <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#101522" />
            <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0" />
                <GradientStop Color="#1E1E2E" Offset="0.5" />
                <GradientStop Color="#111111" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="SidebarDividerBrush" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="SidebarFooterPrimaryBrush" Color="#44FFFFFF" />
            <SolidColorBrush x:Key="SidebarFooterSecondaryBrush" Color="#88A4C9" />
            <SolidColorBrush x:Key="SidebarLogoBrush" Color="#007ACC" />
            <SolidColorBrush x:Key="SidebarIconInactiveBrush" Color="#ABB2BF" />
            <SolidColorBrush x:Key="SidebarIconActiveBrush" Color="#00AADE" />
            <SolidColorBrush x:Key="SidebarItemForegroundBrush" Color="#BBFFFFFF" />
            <SolidColorBrush x:Key="SidebarItemSelectedForegroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="#25FFFFFF" />
            <SolidColorBrush x:Key="SidebarItemHoverBackgroundBrush" Color="#10FFFFFF" />

            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#F3F8FF" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#B2C0D6" />
            <SolidColorBrush x:Key="AppTextMutedBrush" Color="#8FA2BF" />

            <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="AppCardBorderBrush" Color="#25FFFFFF" />

            <SolidColorBrush x:Key="DashboardCardBackgroundBrush" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="DashboardCardBorderBrush" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="DashboardGaugeTrackBrush" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="DashboardIconBrush" Color="#93A8C3" />
            <SolidColorBrush x:Key="DashboardTextPrimaryBrush" Color="#F3F8FF" />
            <SolidColorBrush x:Key="DashboardTextSecondaryBrush" Color="#B2C0D6" />
            <SolidColorBrush x:Key="DashboardTextMutedBrush" Color="#9DB0CB" />
            <SolidColorBrush x:Key="DashboardTextTertiaryBrush" Color="#8FA2BF" />
            <SolidColorBrush x:Key="DashboardSectionTitleBrush" Color="#D9E5F7" />
            <SolidColorBrush x:Key="DashboardDividerBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayBackgroundBrush" Color="#35060A1B" />
            <SolidColorBrush x:Key="DashboardOverlayCardBackgroundBrush" Color="#1EFFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayCardBorderBrush" Color="#3AFFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayTextBrush" Color="#DCE7FA" />
            <SolidColorBrush x:Key="DashboardOverlayProgressBrush" Color="#27A4FF" />

            <Style TargetType="TextBlock" x:Key="HeaderStyle">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                <Setter Property="Margin" Value="0,0,0,25" />
            </Style>

            <Style TargetType="Border" x:Key="CardStyle">
                <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Margin" Value="0,0,15,15" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.2" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBlock" x:Key="InfoLabel">
                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style TargetType="TextBlock" x:Key="InfoValue">
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="Medium" />
            </Style>

            <Style TargetType="ListBoxItem" x:Key="SidebarItemStyle">
                <Setter Property="Padding" Value="15,12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="12,4" />
                <Setter Property="Foreground" Value="{DynamicResource SidebarItemForegroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Name="Border" CornerRadius="12" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemSelectedBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SidebarItemSelectedForegroundBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemHoverBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SidebarItemSelectedForegroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
