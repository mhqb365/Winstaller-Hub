<Application x:Class="WinstallerHubApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA" />

            <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#0B0F19" />
            <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0.1,0" EndPoint="0.9,1">
                <GradientStop Color="#0B0F19" Offset="0" />
                <GradientStop Color="#111827" Offset="0.5" />
                <GradientStop Color="#1E1B4B" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#22000000" />
            <SolidColorBrush x:Key="SidebarDividerBrush" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="SidebarFooterPrimaryBrush" Color="#55FFFFFF" />
            <SolidColorBrush x:Key="SidebarFooterSecondaryBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="SidebarLogoBrush" Color="#818CF8" />
            <SolidColorBrush x:Key="SidebarIconInactiveBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="SidebarIconActiveBrush" Color="#818CF8" />
            <SolidColorBrush x:Key="SidebarItemForegroundBrush" Color="#D1D5DB" />
            <SolidColorBrush x:Key="SidebarItemSelectedForegroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="#2AFFFFFF" />
            <SolidColorBrush x:Key="SidebarItemHoverBackgroundBrush" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="SidebarItemHoverSelectedBrush" Color="#33FFFFFF" />

            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#CBD5E1" />
            <SolidColorBrush x:Key="AppTextMutedBrush" Color="#94A3B8" />

            <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#0AFFFFFF" />
            <SolidColorBrush x:Key="AppCardBorderBrush" Color="#1AFFFFFF" />

            <SolidColorBrush x:Key="DashboardCardBackgroundBrush" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="DashboardCardBorderBrush" Color="#1CFFFFFF" />
            <SolidColorBrush x:Key="DashboardGaugeTrackBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="DashboardIconBrush" Color="#A78BFA" />
            <SolidColorBrush x:Key="DashboardTextPrimaryBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="DashboardTextSecondaryBrush" Color="#CBD5E1" />
            <SolidColorBrush x:Key="DashboardTextMutedBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="DashboardTextTertiaryBrush" Color="#64748B" />
            <SolidColorBrush x:Key="DashboardSectionTitleBrush" Color="#E2E8F0" />
            <SolidColorBrush x:Key="DashboardDividerBrush" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayBackgroundBrush" Color="#55020617" />
            <SolidColorBrush x:Key="DashboardOverlayCardBackgroundBrush" Color="#1EFFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayCardBorderBrush" Color="#2AFFFFFF" />
            <SolidColorBrush x:Key="DashboardOverlayTextBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="DashboardOverlayProgressBrush" Color="#818CF8" />

            <Style TargetType="TextBlock" x:Key="HeaderStyle">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                <Setter Property="Margin" Value="0,0,0,30" />
            </Style>

            <Style TargetType="Border" x:Key="CardStyle">
                <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="Padding" Value="24" />
                <Setter Property="Margin" Value="0,0,15,20" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.15" Color="Black" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBlock" x:Key="InfoLabel">
                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style TargetType="TextBlock" x:Key="InfoValue">
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Medium" />
            </Style>

            <Style TargetType="ListBoxItem" x:Key="SidebarItemStyle">
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="14,6" />
                <Setter Property="Foreground" Value="{DynamicResource SidebarItemForegroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Name="Border" CornerRadius="16" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemSelectedBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SidebarItemSelectedForegroundBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemHoverBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SidebarItemSelectedForegroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ListView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,14" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Name="Border" CornerRadius="12" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemHoverBackgroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemSelectedBackgroundBrush}" />
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True" />
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarItemHoverSelectedBrush}" />
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="12,12,12,16" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Grid>
                                <Border Background="{TemplateBinding Background}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SidebarDividerBrush}">
                                    <TextBlock Text="{TemplateBinding Content}" Padding="{TemplateBinding Padding}" Margin="0,0,0,0" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
