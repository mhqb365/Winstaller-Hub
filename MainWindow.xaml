<Window x:Class="WinstallerHubApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        ui:WindowHelper.UseModernWindowStyle="True"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        Title="Winstaller Hub" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Custom Sidebar Logo Header -->
        <ControlTemplate x:Key="SidebarHeader">
            <StackPanel Margin="20,30,20,30">
                <TextBlock Text="Winstaller Hub" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource SidebarLogoBrush}" VerticalAlignment="Center" />
                <!-- <TextBlock Text="Winstaller Hub" FontSize="12" Foreground="Gray" Opacity="0.8" /> -->
            </StackPanel>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <!-- Immersive Gradient Background -->
        <Border Grid.ColumnSpan="2"
                Background="{DynamicResource ShellBackgroundBrush}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Translucent Sidebar -->
            <Border Background="{DynamicResource SidebarBackgroundBrush}" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ContentControl Template="{StaticResource SidebarHeader}" Grid.Row="0" />

                    <ListBox x:Name="SidebarListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="Sidebar_SelectionChanged" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <StaticResource ResourceKey="SidebarItemStyle" />
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem Tag="Dashboard" IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home" Foreground="{DynamicResource SidebarIconActiveBrush}" Margin="0,0,15,0" />
                                <TextBlock x:Name="DashboardNavTextBlock" Text="" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </ListBoxItem>
                        
                        <ListBoxItem Tag="Software">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Download" Foreground="{DynamicResource SidebarIconInactiveBrush}" Margin="0,0,15,0" />
                                <TextBlock x:Name="SoftwareNavTextBlock" Text="" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="Optimize">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Repair" Foreground="{DynamicResource SidebarIconInactiveBrush}" Margin="0,0,15,0" />
                                <TextBlock x:Name="OptimizeNavTextBlock" Text="" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </ListBoxItem>

                        <!-- Office Menu Section -->
                        <ListBoxItem x:Name="OfficeHeader" Tag="OfficeHeader" Margin="12,4,12,4">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;" Foreground="{DynamicResource SidebarIconInactiveBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0" />
                                    <TextBlock x:Name="OfficeNavTextBlock" Text="Office" VerticalAlignment="Center" FontSize="15" FontWeight="Normal" Opacity="0.9" />
                                </StackPanel>
                                <TextBlock x:Name="OfficeChevron" FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" Opacity="0.4" />
                            </Grid>
                        </ListBoxItem>

                        <!-- Sub-menu Items with Vertical Line -->

                        <ListBoxItem x:Name="OfficeImageItem" Tag="OfficeImage" Margin="42,2,12,2" Padding="20,10,15,10" Visibility="Collapsed">
                            <Grid>
                                <Border BorderBrush="{DynamicResource SidebarDividerBrush}" BorderThickness="1,0,0,0" HorizontalAlignment="Left" Margin="-20,-10,0,-10" Opacity="0.6" />
                                <TextBlock x:Name="OfficeImageNavTextBlock" Text="" VerticalAlignment="Center" FontSize="14" Opacity="0.8" />
                            </Grid>
                        </ListBoxItem>

                        <ListBoxItem x:Name="OfficeOnlineItem" Tag="OfficeOnline" Margin="42,2,12,4" Padding="20,10,15,10" Visibility="Collapsed">
                            <Grid>
                                <Border BorderBrush="{DynamicResource SidebarDividerBrush}" BorderThickness="1,0,0,0" HorizontalAlignment="Left" Margin="-20,-10,0,10" Opacity="0.6" />
                                <TextBlock x:Name="OfficeOnlineNavTextBlock" Text="" VerticalAlignment="Center" FontSize="14" Opacity="0.8" />
                            </Grid>
                        </ListBoxItem>

                        <ListBoxItem Tag="Settings">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Setting" Foreground="{DynamicResource SidebarIconInactiveBrush}" Margin="0,0,15,0" />
                                <TextBlock x:Name="SettingsNavTextBlock" Text="" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                    
                    <StackPanel Grid.Row="2" Margin="25,0,25,25">
                        <Border Height="1" Background="{DynamicResource SidebarDividerBrush}" Margin="0,0,0,20" />
                        <TextBlock Text="v2.0.0" HorizontalAlignment="Left" Foreground="{DynamicResource SidebarFooterPrimaryBrush}" FontSize="11" />
                        <TextBlock x:Name="BylineTextBlock"
                                   Text=""
                                   HorizontalAlignment="Left"
                                   Foreground="{DynamicResource SidebarFooterSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area with semi-transparent glass frame -->
            <Border Grid.Column="1" Background="Transparent">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Padding="40,30,40,30" />
            </Border>
        </Grid>

        <Border x:Name="ToastHostBorder"
                Panel.ZIndex="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,18,0"
                MaxWidth="420"
                Padding="14,12"
                CornerRadius="12"
                BorderThickness="1"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Opacity="0">
            <StackPanel>
                <TextBlock x:Name="ToastTitleTextBlock"
                           Text=""
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#F9FBFF" />
                <TextBlock x:Name="ToastMessageTextBlock"
                           Text=""
                           FontSize="13"
                           Margin="0,4,0,0"
                           Foreground="#EAF2FF"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
