<Page x:Class="WinstallerHubApp.Views.ActivationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="ActivationPage"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
        <StackPanel>
            <TextBlock x:Name="PageTitleTextBlock" Text="" Style="{StaticResource HeaderStyle}" />
            <TextBlock x:Name="PageDescriptionTextBlock" Text="" Foreground="{DynamicResource AppTextSecondaryBrush}" FontSize="15" Margin="0,-20,0,30" Opacity="0.9" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Official Key Card -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#1A60A5FA" CornerRadius="12" Padding="12">
                                <ui:SymbolIcon Symbol="Permissions" Foreground="{DynamicResource AccentBrush}" />
                            </Border>
                            <TextBlock x:Name="OfficialMethodTitleBlock" Text="" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="OfficialMethodDescBlock" Text="" TextWrapping="Wrap" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="13" Margin="0,0,0,25" MinHeight="40" />
                        
                        <TextBox x:Name="ProductKeyTextBox" FontSize="14" Padding="12,10" Margin="0,0,0,15" />
                        
                        <Button x:Name="ActivateButton" Content="" HorizontalAlignment="Stretch" Padding="15,10" FontSize="14" Click="ActivateButton_Click" />
                    </StackPanel>
                </Border>

                <!-- MAS Script Card -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="2" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#1A10B981" CornerRadius="12" Padding="12">
                                <ui:SymbolIcon Symbol="Repair" Foreground="#10B981" />
                            </Border>
                            <TextBlock x:Name="MASMethodTitleBlock" Text="" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="MASMethodDescBlock" Text="" TextWrapping="Wrap" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="13" Margin="0,0,0,25" MinHeight="40" />
                        
                        <Border Background="#0AFFFFFF" BorderBrush="{DynamicResource AppCardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                            <TextBlock Text="irm https://get.activated.win | iex" FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="RunMASWindowsButton" Grid.Column="0" Content="" HorizontalAlignment="Stretch" Padding="15,10" FontSize="14" Click="RunMASWindowsButton_Click" Background="#10B981" Foreground="White" BorderThickness="0">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                </Button.Resources>
                            </Button>

                            <Button x:Name="RunMASOfficeButton" Grid.Column="2" Content="" HorizontalAlignment="Stretch" Padding="15,10" FontSize="14" Click="RunMASOfficeButton_Click" Background="#60A5FA" Foreground="White" BorderThickness="0">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#3B82F6" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2563EB" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
