<Page x:Class="WinstallerHubApp.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WinstallerHubApp.Views"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="850"
      Title="Dashboard"
      Background="Transparent"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DashboardCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DashboardCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="MinHeight" Value="160" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.18"
                                      Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DashboardCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DashboardCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="MinHeight" Value="220" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.18"
                                      Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type local:OsCardViewModel}">
            <Border Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100" />
                        <RowDefinition Height="62" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Width="124"
                          Height="86"
                          HorizontalAlignment="Center"
                          Margin="0,4,0,10">
                        <TextBlock Text="&#xE770;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="48"
                                   Foreground="{DynamicResource DashboardIconBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource DashboardTextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:GaugeCardViewModel}">
            <Border Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100" />
                        <RowDefinition Height="62" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Width="124" Height="86" HorizontalAlignment="Center" Margin="0,4,0,10">
                        <Path Data="M12,72 A50,50 0 0 1 112,72"
                              Stroke="{DynamicResource DashboardGaugeTrackBrush}"
                              StrokeThickness="8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Polyline Points="{Binding ArcPoints}"
                                  Stroke="{Binding StrokeBrush}"
                                  StrokeThickness="8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />

                        <StackPanel VerticalAlignment="Center" Margin="0,14,0,0">
                            <TextBlock Text="{Binding PercentText}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Value}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DashboardTextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource DashboardTextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:NetworkCardViewModel}">
            <Border Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="&#xE701;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{DynamicResource DashboardIconBrush}"
                                   Margin="0,0,8,0" />
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="{Binding StatusBrush}"
                                 VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Title}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="{Binding Value}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DashboardTextPrimaryBrush}" />
                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource DashboardTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Detail}"
                                   FontSize="12"
                                   Foreground="{DynamicResource DashboardTextTertiaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:SystemDetailPanelViewModel}">
            <Border Style="{StaticResource DetailPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource DashboardIconBrush}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontSize="13"
                                               Foreground="{DynamicResource DashboardTextMutedBrush}"
                                               Margin="0,0,8,0"
                                               TextTrimming="CharacterEllipsis" />

                                     <TextBlock Grid.Row="0"
                                                Grid.Column="1"
                                                Text="{Binding Value}"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource DashboardTextPrimaryBrush}"
                                                HorizontalAlignment="Right"
                                                TextAlignment="Right"
                                                TextWrapping="Wrap" />

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Height="1"
                                            Background="{DynamicResource DashboardDividerBrush}"
                                            Margin="0,8,0,2" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <ScrollViewer x:Name="CardsScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="{Binding ViewportWidth, ElementName=CardsScrollViewer}">
                <ItemsControl x:Name="AllCardsItemsControl"
                              Margin="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock x:Name="SystemInfoHeaderTextBlock"
                           Text=""
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource DashboardSectionTitleBrush}"
                           Margin="16,4,16,4" />

                <Grid Margin="10,0,10,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ItemsControl x:Name="SystemDetailsLeftItemsControl"
                                  Grid.Column="0"
                                  Margin="0,0,6,0" />

                    <ItemsControl x:Name="SystemDetailsRightItemsControl"
                                  Grid.Column="1"
                                  Margin="6,0,0,0" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="InitialLoadingOverlay"
              Background="{DynamicResource DashboardOverlayBackgroundBrush}"
              Visibility="Collapsed"
              IsHitTestVisible="True">
            <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="18,16"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource DashboardOverlayCardBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource DashboardOverlayCardBackgroundBrush}">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True"
                                 Width="210"
                                 Height="4"
                                 Foreground="{DynamicResource DashboardOverlayProgressBrush}"
                                 Margin="0,0,0,12" />
                    <TextBlock x:Name="LoadingStatusTextBlock"
                               Text=""
                               Foreground="{DynamicResource DashboardOverlayTextBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

