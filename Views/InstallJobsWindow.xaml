<Window x:Class="WinstallerHubApp.Views.InstallJobsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="560"
        Width="980"
        MinHeight="480"
        MinWidth="840"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextPrimaryBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock x:Name="PageTitleTextBlock"
                       Text=""
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AppTextPrimaryBrush}" />
            <TextBlock x:Name="PageDescriptionTextBlock"
                       Text=""
                       FontSize="14"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <Button x:Name="RefreshButton"
                    Content=""
                    Height="34"
                    Padding="14,0"
                    Click="RefreshButton_Click" />
            <Button x:Name="ClearCompletedButton"
                    Content=""
                    Height="34"
                    Padding="14,0"
                    Margin="10,0,0,0"
                    Click="ClearCompletedButton_Click" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="{DynamicResource AppCardBackgroundBrush}"
                BorderBrush="{DynamicResource AppCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="SummaryTextBlock"
                           Text=""
                           FontSize="13"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource AppTextMutedBrush}" />

                <ListView x:Name="JobsListView"
                          Grid.Row="1"
                          BorderBrush="{DynamicResource AppCardBorderBrush}"
                          BorderThickness="1"
                          Margin="0,0,0,8">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn x:Name="JobActionColumn"
                                             Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding CancelText}"
                                                Tag="{Binding JobId}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                                                Click="CancelButton_Click"
                                                Padding="8,2"
                                                Height="26"
                                                FontSize="11"
                                                Background="#33FF4444"
                                                BorderBrush="#99FF4444"
                                                Foreground="#FFFF8888" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn x:Name="JobAppColumn"
                                            Width="180"
                                            DisplayMemberBinding="{Binding DisplayName}" />
                            <GridViewColumn x:Name="JobPackageColumn"
                                            Width="190"
                                            DisplayMemberBinding="{Binding PackageId}" />
                            <GridViewColumn x:Name="JobStateColumn"
                                            Width="120"
                                            DisplayMemberBinding="{Binding StateText}" />
                            <GridViewColumn x:Name="JobStartedColumn"
                                            Width="150"
                                            DisplayMemberBinding="{Binding StartedAtText}" />
                            <GridViewColumn x:Name="JobCompletedColumn"
                                            Width="150"
                                            DisplayMemberBinding="{Binding CompletedAtText}" />
                            <GridViewColumn x:Name="JobDetailColumn"
                                             Width="240"
                                             DisplayMemberBinding="{Binding Detail}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock x:Name="EmptyTextBlock"
                           Grid.Row="2"
                           Text=""
                           FontSize="13"
                           Foreground="{DynamicResource AppTextMutedBrush}"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <Button Grid.Row="3"
                x:Name="CloseButton"
                Content=""
                Height="34"
                Padding="18,0"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="CloseButton_Click" />
    </Grid>
</Window>
