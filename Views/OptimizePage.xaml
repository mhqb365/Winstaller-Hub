<Page x:Class="WinstallerHubApp.Views.OptimizePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="850"
      Title="Optimize">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="PageTitleTextBlock" Text="" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center" />
            <TextBlock x:Name="PageDescriptionTextBlock" Text="" FontSize="16" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>

